{
  "name": "dom-to-figma-plugin",
  "version": "1.0.0",
  "description": "Import DOM designs into Figma",
  "scripts": {
    "build": "esbuild src/code.ts --bundle --outfile=dist/code.js && cp src/ui.html dist/ui.html",
    "watch": "esbuild src/code.ts --bundle --outfile=dist/code.js --watch"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.0.0"
  }
}
